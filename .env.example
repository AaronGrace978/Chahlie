# Chahlie Configuration
# Copy this to .env and add your API key

# ===== OLLAMA CLOUD (Recommended) =====
# Get your API key from https://ollama.com/settings/keys
OLLAMA_API_KEY=your-ollama-cloud-api-key-here

# Choose your model (see https://ollama.com/search?c=cloud)
# 
# TOP PICKS FOR AGENTIC CODING:
#   kimi-k2.6:cloud   - 256K context, long-horizon coding, tools, vision (default)
#   glm-5.1           - SOTA for agentic engineering
#   qwen3.5           - Multimodal powerhouse (6.3M pulls)
#   devstral-small-2  - Excels at multi-file editing (24B)
#   gemma4            - Frontier performance + vision
#   deepseek-v3.2     - Efficient reasoning + agent performance
#   minimax-m2.7      - Latest for coding & productivity
#
OLLAMA_CLOUD_MODEL=kimi-k2.6:cloud

# Backend: "ollama-cloud" (default), "ollama-local", "openai-compatible", or "anthropic"
CHAHLIE_BACKEND=ollama-cloud

# ===== LOCAL OLLAMA (Optional) =====
# For self-hosted Ollama instance
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_LOCAL_MODEL=qwen3:8b
# CHAHLIE_BACKEND=ollama-local

# ===== LLAMA PROXY / OpenAI-compatible (Optional) =====
# Run: python -m chahlie.llama_proxy --port 11435
# CHAHLIE_BACKEND=openai-compatible
# OPENAI_COMPATIBLE_URL=http://127.0.0.1:11435/v1
# OPENAI_COMPATIBLE_MODEL=qwen3:8b
# OPENAI_COMPATIBLE_API_KEY=optional-shared-secret

# ===== ANTHROPIC (Legacy) =====
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# CHAHLIE_BACKEND=anthropic

# ===== v2.4 "Juice Box" upgrades =====

# Persistent semantic memory (ChromaDB). Default on; harmless if chromadb
# isn't installed (Chahlie falls back to in-process vectors).
# CHAHLIE_PERSISTENT_VECTORS=true

# Tree-of-Thoughts planning for big tasks. Adds 2 small LLM calls per
# qualifying turn. Pairs well with a small/fast TOT_MODEL.
# CHAHLIE_TOT_PLANNING=true
# CHAHLIE_TOT_MIN_TASK_CHARS=140
# CHAHLIE_TOT_CANDIDATES=3
# CHAHLIE_TOT_MODEL=qwen3.5:cloud

# Multi-model fallback chain - comma-separated. Kicks in only when the
# primary model exhausts retries with a transient error.
# CHAHLIE_FALLBACK_MODELS=glm-5.1,devstral-small-2
