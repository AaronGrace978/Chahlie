{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chahlie",
  "version": "2.6.5",
  "identifier": "com.cursorboston.chahlie",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chahlie",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../chahlie",
      "../../pyproject.toml",
      "../../requirements-tauri.txt",
      "../../requirements-deck.txt",
      "../../requirements.txt",
      "../../.env.deck.example"
    ],
    "linux": {
      "deb": {
        "depends": ["python3", "python3-venv"]
      }
    }
  }
}
