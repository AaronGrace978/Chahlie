# Chahlie Steam Deck Edition — recommended settings
# Copy to .env on your Deck:  cp .env.deck.example .env

# ===== BACKEND =====
# Cloud works great when online. Local Ollama is better offline on Deck.
CHAHLIE_BACKEND=ollama-cloud
OLLAMA_API_KEY=your-ollama-cloud-api-key-here
OLLAMA_CLOUD_MODEL=qwen3.5:cloud
# Fast backup when cloud hiccups (skip heavy models on Deck Wi‑Fi):
CHAHLIE_FALLBACK_MODELS=glm-5.1:cloud
# Route short banter to the same fast model:
CHAHLIE_SMALL_MODEL=qwen3.5:cloud

# ===== DECK PERF (handheld Wi‑Fi) =====
CHAHLIE_OLLAMA_TIMEOUT=18
CHAHLIE_HISTORY_TOOL_CHAR_CAP=800
CHAHLIE_COMPACT_THRESHOLD_CHARS=16000
CHAHLIE_COMPACT_PRESERVE_RECENT=4
CHAHLIE_DECK_MAX_RETRIES=2
CHAHLIE_DECK_SOCIAL_LOCAL_CHARS=80

# ===== DECK UI =====
CHAHLIE_DECK_MODE=true
# Work from HOME so Chahlie scans YOUR files, not the install folder
CHAHLIE_WORKDIR=/home/deck
CHAHLIE_STREAMING=true
CHAHLIE_REQUIRE_APPROVAL=true

# Lighter memory on handheld
CHAHLIE_PERSISTENT_VECTORS=false
CHAHLIE_SEMANTIC_MEMORY=false

# Social fast-path keeps banter snappy (most short chat stays local on Deck)
CHAHLIE_SOCIAL_FAST_PATH=true
CHAHLIE_SOCIAL_MAX_REPLY_LINES=3
CHAHLIE_SOCIAL_MAX_REPLY_CHARS=280

# ===== VOICE =====
CHAHLIE_VOICE=true
CHAHLIE_VOICE_TTS=true
CHAHLIE_VOICE_LANGUAGE=en-US
CHAHLIE_VOICE_TIMEOUT=8
CHAHLIE_VOICE_TTS_RATE=175

# ===== LLAMA PROXY (optional — use a friend's GPU or your own) =====
# CHAHLIE_BACKEND=openai-compatible
# OPENAI_COMPATIBLE_URL=http://192.168.1.50:11435/v1
# OPENAI_COMPATIBLE_MODEL=qwen3:8b
# OPENAI_COMPATIBLE_API_KEY=shared-secret-if-proxy-requires-it

# Offline speech-to-text (optional — download from https://alphacephei.com/vosk/models)
# CHAHLIE_VOSK_MODEL=/home/deck/.local/share/vosk-model-small-en-us-0.15
